# Optional for AI analysis. Without this key, the app returns a rules-only report.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_FAST_MODEL=gpt-5.4-mini

# Optional fallback token for private repositories or higher public API rate limits.
GITHUB_TOKEN=

# GitHub App integration. Required for automatic PR review via webhook.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Auto review behavior.
GITHUB_APP_REVIEW_MODE=deep
GITHUB_APP_REVIEW_DRAFTS=false
GITHUB_APP_MAX_INLINE_COMMENTS=8
GITHUB_APP_REQUEST_CHANGES=false
GITHUB_APP_SKIP_DUPLICATE_REVIEWS=true

# Comment bot trigger used in PR issue comments.
PR_INSIGHT_BOT_TRIGGER=/pr-insight

# File-based persistence for jobs, reports, audit logs and feedback.
PR_INSIGHT_DATA_DIR=.data
